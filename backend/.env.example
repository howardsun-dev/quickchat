# QuickChat backend environment variables
# Copy this file to backend/.env and replace placeholder values.
# Never commit real secrets.

# Runtime
NODE_ENV=development
PORT=3000

# Frontend origin used by CORS, emails, and/or deployment callbacks.
# Local Vite dev server default:
CLIENT_URL=http://localhost:5173

# Database
# Local example: mongodb://127.0.0.1:27017/quickchat
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quickchat?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/quickchat

# Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Arcjet rate limiting / bot protection
ARCJET_KEY=your-arcjet-key
ARCJET_ENV=development

# Password reset email via Resend
# Optional unless password reset emails are enabled/tested locally.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=QuickChat
